*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, Helvetica, sans-serif;
}

body{
  background:#f4f6fa;
}

.app{
  display:flex;
  height:100vh;
}

.sidebar{
  width:260px;
  background:#1f2937;
  color:white;
  padding:25px;
  display:flex;
  flex-direction:column;
  gap:15px;
}

.sidebar h1{
  font-size:24px;
  margin-bottom:20px;
}

.sidebar button{
  padding:14px;
  border:none;
  border-radius:10px;
  cursor:pointer;
  background:transparent;
  color:white;
  text-align:left;
  font-size:16px;
}

.sidebar button:hover{
  background:#374151;
}

.content{
  flex:1;
  padding:40px;
  overflow:auto;
}

.card{
  margin-top:30px;
  background:white;
  padding:25px;
  border-radius:15px;
  box-shadow:0 2px 10px rgba(0,0,0,.08);
  width:420px;
}

.page-header{
  margin-bottom:24px;
}

.stats-grid{
  display:grid;
  gap:18px;
  grid-template-columns:repeat(3,minmax(0,1fr));
  max-width:980px;
}

.wide-card{
  max-width:980px;
  width:100%;
}

.exam-shell{
  max-width:980px;
}

.exam-header{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:20px;
}

.eyebrow{
  color:#64748b;
  font-size:14px;
  font-weight:700;
  letter-spacing:.04em;
  margin-bottom:6px;
  text-transform:uppercase;
}

.score-pill{
  background:#e0f2fe;
  border:1px solid #bae6fd;
  border-radius:999px;
  color:#075985;
  font-weight:700;
  padding:10px 14px;
  white-space:nowrap;
}

.progress-bar{
  background:#e5e7eb;
  border-radius:999px;
  height:10px;
  margin-top:22px;
  overflow:hidden;
}

.progress-fill{
  background:#2563eb;
  height:100%;
  transition:width .2s ease;
}

.exam-card{
  width:100%;
}

.case-text{
  line-height:1.6;
  margin-bottom:24px;
  white-space:pre-line;
}

.options-list{
  display:grid;
  gap:12px;
  margin:18px 0 24px;
}

.option-row{
  align-items:flex-start;
  border:1px solid #d1d5db;
  border-radius:10px;
  cursor:pointer;
  display:flex;
  gap:10px;
  padding:14px;
}

.option-row.selected{
  border-color:#2563eb;
  background:#eff6ff;
}

.option-row.correct{
  border-color:#16a34a;
  background:#f0fdf4;
}

.option-row.wrong{
  border-color:#dc2626;
  background:#fef2f2;
}

.feedback{
  border-top:1px solid #e5e7eb;
  margin-top:24px;
  padding-top:20px;
}

.results-grid{
  display:grid;
  gap:16px;
  grid-template-columns:repeat(3,minmax(0,1fr));
  margin-top:24px;
}

.result-card{
  background:white;
  border-radius:14px;
  box-shadow:0 2px 10px rgba(0,0,0,.08);
  padding:22px;
}

.result-card span{
  color:#64748b;
  display:block;
  font-size:14px;
  margin-bottom:8px;
}

.result-card strong{
  font-size:34px;
}

.review-list{
  margin:14px 0 0 20px;
}

.specialty-list{
  display:grid;
  gap:14px;
}

.specialty-row{
  align-items:center;
  display:grid;
  gap:14px;
  grid-template-columns:180px 1fr 110px;
}

.mini-bar{
  background:#e5e7eb;
  border-radius:999px;
  height:10px;
  overflow:hidden;
}

.mini-bar div{
  background:#2563eb;
  height:100%;
}

.library-grid{
  display:grid;
  gap:18px;
  grid-template-columns:repeat(2,minmax(0,1fr));
}

.library-card{
  margin-top:0;
  min-height:190px;
  width:100%;
}

button{
  background:#2563eb;
  border:0;
  border-radius:10px;
  color:white;
  cursor:pointer;
  font-weight:700;
  padding:12px 16px;
}

button:hover{
  background:#1d4ed8;
}

.sidebar button{
  font-weight:400;
}
